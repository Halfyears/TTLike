generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  accountStatus String    @default("ACTIVE") @map("account_status")  // PENDING | ACTIVE | INACTIVE | DELETED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  affiliateCode      String?
  whitelabelPdfPasses Int    @default(0)

  subscription  UserSubscription?
  analytics     UserAnalytic[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model UserSubscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  stripeCustomerId  String?
  stripeSubId       String?
  paypalSubId       String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model TiktokVideo {
  id            String    @id @default(uuid())
  videoId       String    @unique
  title         String
  description   String?
  authorName    String
  authorHandle  String
  viewCount     BigInt    @default(0)
  likeCount     BigInt    @default(0)
  shareCount    BigInt    @default(0)
  commentCount  BigInt    @default(0)
  thumbnailUrl      String?
  videoUrl          String?
  authorAvatarUrl   String?
  hashtags      String[]
  productLink   String?
  productName   String?
  productPrice  Decimal?
  niche         String?
  viralScore    Float     @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  aiBreakdown   AiBreakdown?

  @@map("tiktok_videos")
}

model AiBreakdown {
  id             String      @id @default(uuid())
  videoId        String      @unique
  hookType       String
  hookText       String?
  hookScore      Float       @default(0)
  emotionTrigger String?
  ctaStyle       String?
  targetAudience String?
  productFit     String?
  whyItWorks     String?
  scriptTemplate String?
  keyInsights    String[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  video          TiktokVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("ai_breakdowns")
}

model HookPattern {
  id          String    @id @default(uuid())
  hookType    HookType
  title       String
  template    String
  example     String?
  niche       String?
  viralScore  Float     @default(0)
  useCount    Int       @default(0)
  tags        String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("hook_patterns")
}

enum HookType {
  SURPRISE
  QUESTION
  EMOTIONAL
  FOMO
  CONTRARIAN
  STORY
  EDUCATIONAL
}

model TrendingTopic {
  id            String    @id @default(uuid())
  topic         String
  hashtag       String?
  category      String?
  viralScore    Float     @default(0)
  videoCount    Int       @default(0)
  growthRate    Float     @default(0)
  peakDate      DateTime?
  region        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("trending_topics")
}

model BlogPost {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?     @map("cover_image")
  category    String?
  tags        String[]
  authorName  String      @default("TTLike Team") @map("author_name")
  authorImage String?     @map("author_image")
  status      PostStatus  @default(DRAFT)
  seoTitle    String?     @map("seo_title")
  seoDesc     String?     @map("seo_desc")
  viewCount   Int         @default(0) @map("view_count")
  publishedAt DateTime?   @map("published_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("blog_posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model UserAnalytic {
  id         String   @id @default(uuid())
  userId     String
  event      String
  page       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_analytics")
}

model PaymentConfig {
  id            String   @id @default(uuid())
  provider      String   @unique  // 'stripe' | 'paypal'
  mode          String   @default("sandbox")  // 'sandbox' | 'live'
  secretKey     String?
  publicKey     String?
  webhookSecret String?
  clientId      String?  // PayPal client ID
  extraConfig   Json?
  isEnabled     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payment_configs")
}

model SpamRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  ruleType    String   // 'disposable_email' | 'email_pattern' | 'registration_rate' | 'manual_flag'
  config      Json?
  autoAction  String?  // 'flag' | 'set_pending' | 'set_inactive' | null
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("spam_rules")
}

model AffiliateLink {
  id          String   @id @default(uuid())
  userId      String?
  code        String   @unique
  destination String
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Decimal  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("affiliate_links")
}
