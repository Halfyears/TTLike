generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription  UserSubscription?
  analytics     UserAnalytic[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model UserSubscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  stripeCustomerId  String?
  stripeSubId       String?
  paypalSubId       String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model TiktokVideo {
  id            String    @id @default(uuid())
  videoId       String    @unique
  title         String
  description   String?
  authorName    String
  authorHandle  String
  viewCount     BigInt    @default(0)
  likeCount     BigInt    @default(0)
  shareCount    BigInt    @default(0)
  commentCount  BigInt    @default(0)
  thumbnailUrl      String?
  videoUrl          String?
  authorAvatarUrl   String?
  hashtags      String[]
  productLink   String?
  productName   String?
  productPrice  Decimal?
  niche         String?
  viralScore    Float     @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  aiBreakdown   AiBreakdown?

  @@map("tiktok_videos")
}

model AiBreakdown {
  id             String      @id @default(uuid())
  videoId        String      @unique
  hookType       String
  hookText       String?
  hookScore      Float       @default(0)
  emotionTrigger String?
  ctaStyle       String?
  targetAudience String?
  productFit     String?
  whyItWorks     String?
  scriptTemplate String?
  keyInsights    String[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  video          TiktokVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("ai_breakdowns")
}

model HookPattern {
  id          String    @id @default(uuid())
  hookType    HookType
  title       String
  template    String
  example     String?
  niche       String?
  viralScore  Float     @default(0)
  useCount    Int       @default(0)
  tags        String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("hook_patterns")
}

enum HookType {
  SURPRISE
  QUESTION
  EMOTIONAL
  FOMO
  CONTRARIAN
  STORY
  EDUCATIONAL
}

model TrendingTopic {
  id            String    @id @default(uuid())
  topic         String
  hashtag       String?
  category      String?
  viralScore    Float     @default(0)
  videoCount    Int       @default(0)
  growthRate    Float     @default(0)
  peakDate      DateTime?
  region        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("trending_topics")
}

model BlogPost {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    String?
  tags        String[]
  authorName  String      @default("TTLike Team")
  authorImage String?
  status      PostStatus  @default(DRAFT)
  seoTitle    String?
  seoDesc     String?
  viewCount   Int         @default(0)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("blog_posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model UserAnalytic {
  id         String   @id @default(uuid())
  userId     String
  event      String
  page       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_analytics")
}

model AffiliateLink {
  id          String   @id @default(uuid())
  userId      String?
  code        String   @unique
  destination String
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Decimal  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("affiliate_links")
}
