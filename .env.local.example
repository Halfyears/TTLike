# =============================================================================
# TTLike Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Supabase (Required for Auth)
# Create project at: https://supabase.com
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Database (Supabase PostgreSQL)
# Found in: Supabase Dashboard > Settings > Database > Connection string
# =============================================================================
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# Google Gemini AI (Required for AI Script Generator + Failover Gateway)
# Get key at: https://aistudio.google.com/apikey (free tier available)
# =============================================================================
GEMINI_API_KEY=AIza...

# =============================================================================
# Groq (Failover Gateway — Provider #1, fastest free tier)
# Get key at: https://console.groq.com/keys
# =============================================================================
GROQ_API_KEY=gsk_...

# =============================================================================
# GitHub Token (Failover Gateway — Provider #3, GitHub Models / gpt-4o-mini)
# Required scopes: none extra needed for GitHub Models inference
# Get token at: https://github.com/settings/tokens
# =============================================================================
GITHUB_TOKEN=ghp_...

# =============================================================================
# Admin
# =============================================================================
ADMIN_EMAIL=admin@yoursite.com

# =============================================================================
# Stripe (DISABLED during Beta - set PAYMENT_ENABLED=true to activate)
# Get keys at: https://stripe.com/docs/keys
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# PayPal (DISABLED during Beta)
# Get credentials at: https://developer.paypal.com
# =============================================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
